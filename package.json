    "@tailwindcss/postcss": "4.1.11",
    "@types/node": "24.3.0",
    "@types/react": "19.1.12",
    "@types/react-dom": "19.1.9",
    "drizzle-kit": "0.31.10",
    "eslint": "9.34.0",
